{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/renderer/globals.d.ts"
  ],
  "references": [
    { "path": "./tsconfig.shared.json" }
  ]
}
