{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "types": ["node"],
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": [
    "src/main.ts",
    "src/main/**/*.ts",
    "src/audio-processor.ts",
    "src/types/**/*.d.ts"
  ],
  "references": [
    { "path": "./tsconfig.shared.json" }
  ]
}
