{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"],
    "lib": ["ES2022", "DOM"]
  },
  "include": ["src/**/*.js", "tests/**/*.js", "tests/**/*.mjs", "*.mjs"],
  "exclude": ["node_modules", "dist", "out", "coverage"]
}
