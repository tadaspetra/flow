{
  "name": "loop",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "build:ts": "tsc --build",
    "build:copy": "node scripts/copy-assets.mjs",
    "build:styles": "tailwindcss -i ./src/renderer/styles/tailwind.input.css -o ./dist/renderer/styles/main.css --minify",
    "build": "npm run build:ts && npm run build:copy && npm run build:styles",
    "clean": "rm -rf dist && find . -name '*.tsbuildinfo' -not -path '*/node_modules/*' -delete",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --build",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "tsx tests/e2e/smoke-electron.test.ts",
    "package:smoke": "node scripts/package-smoke.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run test:e2e && npm run package:smoke"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "^35.1.2",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.36.0",
    "dotenv": "^17.3.1",
    "electron-reload": "^2.0.0-alpha.1",
    "ffmpeg-static": "^5.3.0",
    "node-fetch": "^2.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "ffmpeg-static"
    ]
  }
}
